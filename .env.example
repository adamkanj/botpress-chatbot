# Botpress v12 work-prep starter settings
#
# Keep only non-sensitive defaults here.
# For work environments, keep secrets, auth keys, and private metadata outside this file.

BOTPRESS_IMAGE=ghcr.io/botpress/botpress/server:v12_31_10
BOTPRESS_BIND_HOST=127.0.0.1
BOTPRESS_PORT=3000
BOTPRESS_PRODUCTION=false
BOTPRESS_EXTERNAL_URL=http://localhost:3000

# Local Botpress language server
BOTPRESS_LANG_HOST=botpress-lang
BOTPRESS_LANG_PORT=3100
BOTPRESS_LANG_DIR=/botpress/lang
BOTPRESS_LANG_DIM=100
BOTPRESS_LANG_DOMAIN=bp
BOTPRESS_LANG_METADATA_LOCATION=/botpress/lang/index.json
BOTPRESS_LANG_OFFLINE=false

# First language to preload for offline mode
BOTPRESS_BOOTSTRAP_LANGUAGE=en

# Remote metadata used only during one-time language download
BOTPRESS_LANG_REMOTE_METADATA_URL=https://nyc3.digitaloceanspaces.com/botpress-public/embeddings/index.json
